@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/agent#> .

# Calliope's observation of the same paper Ares observed.
# This file is loaded into its own named graph
# ex:observations/Calliope so the two agents' memories are
# kept separate even though they talk about the same subject.

ex:obs_0002 a ex:Observation ;
    ex:assertedBy  ex:Calliope ;
    ex:hasSubject  ex:Arxiv2401_00123 ;
    ex:observedAt  "2025-01-15T10:42:00Z"^^xsd:dateTime ;
    ex:confidence  "0.75"^^xsd:decimal .
